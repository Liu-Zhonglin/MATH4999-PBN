@article {liu2025alzheimers,
	author = {Zhonglin, Liu and Louxin, Zhang and Ki, Ching Wai},
	title = {Inferring Progressive Disconnection in Alzheimer{\textquoteright}s Disease with Probabilistic Boolean Networks},
	elocation-id = {2025.07.10.664143},
	year = {2025},
	doi = {10.1101/2025.07.10.664143},
	publisher = {Cold Spring Harbor Laboratory},
	abstract = {The modern understanding of Alzheimer{\textquoteright}s disease as a disconnection syndrome presents the challenge of quantifying the directed influence between brain regions. To address this, we apply probabilistic Boolean networks to model effective brain connectivity for the first time, introducing a novel framework for analyzing functional magnetic resonance imaging data from a cohort comprising normal controls, individuals with mild cognitive impairment (MCI), and Alzheimer{\textquoteright}s patients. Our robust statistical analysis identified five significant connections, each exhibiting a linear decline in influence throughout the disease spectrum. We observed a progressive disruption of pathways from the Default Mode Network to the Medial Temporal Lobe, capturing a key psychophysiological mechanism underlying Alzheimer{\textquoteright}s disease. These findings demonstrate the potential of our framework as a powerful tool for modeling network-level dynamics in neurodegeneration.Competing Interest StatementThe authors have declared no competing interest.},
	URL = {https://www.biorxiv.org/content/early/2025/10/17/2025.07.10.664143},
	eprint = {https://www.biorxiv.org/content/early/2025/10/17/2025.07.10.664143.full.pdf},
	journal = {bioRxiv}
}


